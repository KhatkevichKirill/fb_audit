# Copy to .env and fill in. Point scripts at another file with FB_AUDIT_ENV=/path/.env

# --- Meta Marketing API ---
FB_ACCESS_TOKEN=your_meta_access_token_here
FB_GRAPH_API_VERSION=23.0

# Restrict to specific ad accounts (comma-separated, with or without act_ prefix).
# Leave empty to use every account the token can see.
ACCOUNT_IDS=

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=meta_ads
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- optional ---
# Refresh breakdown materialized views at end of insights_breakdowns_update (1/true/yes)
REFRESH_BREAKDOWN_MVS=
